    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.21",
    "postcss": "8.5.1",
    "promptfoo": "^0.120.27",
    "tailwindcss": "3.4.17",
